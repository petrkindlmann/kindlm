{
  "name": "@kindlm/core",
  "version": "2.3.0",
  "type": "module",
  "license": "MIT",
  "description": "Core engine for KindLM — behavioral regression testing for AI agents",
  "keywords": [
    "ai",
    "llm",
    "testing",
    "agents",
    "tool-calls",
    "assertions",
    "evaluation",
    "compliance",
    "eu-ai-act"
  ],
  "homepage": "https://kindlm.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/petrkindlmann/kindlm.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/petrkindlmann/kindlm/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.0",
    "yaml": "^2.6.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0"
  }
}
