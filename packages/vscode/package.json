{
  "name": "kindlm",
  "displayName": "KindLM",
  "description": "YAML validation, completions, and hover docs for KindLM config files",
  "version": "0.1.0",
  "publisher": "kindlm",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/petrkindlmann/kindlm.git",
    "directory": "packages/vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "Linters",
    "Snippets"
  ],
  "activationEvents": [
    "workspaceContains:kindlm.yaml",
    "workspaceContains:kindlm.yml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "yamlValidation": [
      {
        "fileMatch": "kindlm.yaml",
        "url": "./schemas/kindlm.schema.json"
      },
      {
        "fileMatch": "kindlm.yml",
        "url": "./schemas/kindlm.schema.json"
      }
    ],
    "snippets": [
      {
        "language": "yaml",
        "path": "./snippets/kindlm.code-snippets"
      }
    ]
  },
  "scripts": {
    "build": "esbuild --bundle --platform=node --outdir=dist --external:vscode src/extension.ts",
    "package": "npx vsce package --no-dependencies",
    "publish": "npx vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.0",
    "typescript": "^5.4.0"
  }
}
