{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kindlm.com/schemas/kindlm.schema.json",
  "title": "KindLM Configuration",
  "description": "Schema for kindlm.yaml — behavioral regression test configuration for AI agents.",
  "type": "object",
  "required": ["version", "suites"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "1",
      "description": "Config schema version. Must be \"1\"."
    },
    "defaults": {
      "type": "object",
      "description": "Default settings applied to all suites and tests unless overridden.",
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "pattern": "^(openai|anthropic|gemini|mistral|cohere|ollama):.+$",
          "description": "Default provider and model in \"provider:model\" format (e.g., \"openai:gpt-4o\").",
          "examples": [
            "openai:gpt-4o",
            "anthropic:claude-sonnet-4-5-20250929",
            "ollama:llama3.1"
          ]
        },
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 2,
          "default": 0,
          "description": "Sampling temperature for model responses. 0 = deterministic."
        },
        "runs": {
          "type": "integer",
          "minimum": 1,
          "default": 1,
          "description": "Number of times to run each test for statistical confidence."
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 1,
          "maximum": 128000,
          "default": 1024,
          "description": "Maximum tokens in the model response."
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 1000,
          "default": 60000,
          "description": "Timeout per provider call in milliseconds."
        },
        "concurrency": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32,
          "default": 4,
          "description": "Number of tests to run concurrently."
        },
        "judge_model": {
          "type": "string",
          "pattern": "^(openai|anthropic|gemini|mistral|cohere|ollama):.+$",
          "description": "Default model for LLM-as-judge assertions (e.g., \"openai:gpt-4o\")."
        }
      }
    },
    "providers": {
      "type": "object",
      "description": "Provider configuration. API keys are referenced by environment variable name, never raw values.",
      "additionalProperties": false,
      "properties": {
        "openai": { "$ref": "#/$defs/providerConfig" },
        "anthropic": { "$ref": "#/$defs/providerConfig" },
        "gemini": { "$ref": "#/$defs/providerConfig" },
        "mistral": { "$ref": "#/$defs/providerConfig" },
        "cohere": { "$ref": "#/$defs/providerConfig" },
        "ollama": { "$ref": "#/$defs/ollamaProviderConfig" }
      }
    },
    "suites": {
      "type": "array",
      "description": "Test suites. Each suite groups related tests against a specific agent or system prompt.",
      "minItems": 1,
      "items": { "$ref": "#/$defs/suite" }
    },
    "compliance": {
      "type": "object",
      "description": "EU AI Act Annex IV compliance report settings.",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable compliance report generation."
        },
        "framework": {
          "type": "string",
          "enum": ["eu-ai-act", "custom"],
          "default": "eu-ai-act",
          "description": "Compliance framework to use."
        },
        "output_dir": {
          "type": "string",
          "default": "./compliance-reports",
          "description": "Directory for compliance report output."
        },
        "metadata": {
          "type": "object",
          "description": "Metadata included in the compliance report.",
          "additionalProperties": false,
          "properties": {
            "system_name": {
              "type": "string",
              "description": "Name of the AI system being tested."
            },
            "system_version": {
              "type": "string",
              "description": "Version of the AI system."
            },
            "risk_level": {
              "type": "string",
              "enum": ["high", "limited", "minimal"],
              "description": "AI Act risk classification."
            },
            "operator": {
              "type": "string",
              "description": "Organization operating the AI system."
            },
            "intended_purpose": {
              "type": "string",
              "description": "Documented intended purpose of the AI system."
            },
            "data_governance_notes": {
              "type": "string",
              "description": "Notes on data governance and training data."
            }
          }
        }
      }
    },
    "upload": {
      "type": "object",
      "description": "KindLM Cloud upload settings.",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable automatic upload to KindLM Cloud after test runs."
        },
        "include_artifacts": {
          "type": "boolean",
          "default": false,
          "description": "Upload raw prompt inputs and model outputs. Disabled by default for privacy."
        },
        "redact_patterns": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Regex patterns to redact from artifacts before upload."
        },
        "api_url": {
          "type": "string",
          "format": "uri",
          "default": "https://api.kindlm.com/v1",
          "description": "Cloud API URL. Override for self-hosted deployments."
        }
      }
    }
  },
  "$defs": {
    "providerConfig": {
      "type": "object",
      "description": "Configuration for a provider.",
      "additionalProperties": false,
      "properties": {
        "api_key_env": {
          "type": "string",
          "minLength": 1,
          "description": "Environment variable name containing the API key. Never a raw key."
        },
        "base_url": {
          "type": "string",
          "format": "uri",
          "description": "Custom base URL for API-compatible proxies (e.g., Azure OpenAI, LiteLLM)."
        },
        "organization": {
          "type": "string",
          "description": "Organization ID (OpenAI-specific)."
        }
      }
    },
    "ollamaProviderConfig": {
      "type": "object",
      "description": "Configuration for Ollama (local models).",
      "additionalProperties": false,
      "properties": {
        "api_key_env": {
          "type": "string",
          "description": "Environment variable name containing the API key. Optional for Ollama."
        },
        "base_url": {
          "type": "string",
          "format": "uri",
          "default": "http://localhost:11434",
          "description": "Ollama server URL. Defaults to http://localhost:11434."
        }
      }
    },
    "suite": {
      "type": "object",
      "description": "A test suite groups related tests against a specific agent or system prompt.",
      "required": ["name", "tests"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Unique suite name. Used in reports and JUnit output."
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of what this suite tests."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tags for filtering suites in CLI (e.g., --tags regression)."
        },
        "system_prompt": {
          "type": "string",
          "description": "Inline system prompt for all tests in this suite. Supports {{variable}} interpolation."
        },
        "system_prompt_file": {
          "type": "string",
          "description": "Path to a file containing the system prompt (relative to config file)."
        },
        "provider": {
          "type": "string",
          "pattern": "^(openai|anthropic|gemini|mistral|cohere|ollama):.+$",
          "description": "Override default provider for this suite."
        },
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 2,
          "description": "Override default temperature for this suite."
        },
        "runs": {
          "type": "integer",
          "minimum": 1,
          "description": "Override default run count for this suite."
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 1,
          "maximum": 128000,
          "description": "Override default max tokens for this suite."
        },
        "gates": { "$ref": "#/$defs/gates" },
        "tests": {
          "type": "array",
          "description": "Test cases in this suite.",
          "minItems": 1,
          "items": { "$ref": "#/$defs/test" }
        }
      }
    },
    "test": {
      "type": "object",
      "description": "A single test case that sends input to the agent and evaluates assertions.",
      "required": ["name", "input"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Unique test case name within the suite. Used in reports and JUnit output."
        },
        "input": {
          "type": "string",
          "minLength": 1,
          "description": "User message sent to the agent. Supports {{variable}} interpolation."
        },
        "provider": {
          "type": "string",
          "pattern": "^(openai|anthropic|gemini|mistral|cohere|ollama):.+$",
          "description": "Override provider for this specific test."
        },
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 2,
          "description": "Override temperature for this specific test."
        },
        "runs": {
          "type": "integer",
          "minimum": 1,
          "description": "Override run count for this specific test."
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 1,
          "maximum": 128000,
          "description": "Override max tokens for this specific test."
        },
        "skip": {
          "type": "boolean",
          "default": false,
          "description": "Skip this test case during execution."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tags for filtering tests in CLI (e.g., --tags regression)."
        },
        "vars": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Variables to interpolate into prompt templates."
        },
        "tools": {
          "type": "array",
          "description": "Tool definitions available to the agent for this test case.",
          "items": { "$ref": "#/$defs/toolDefinition" }
        },
        "assert": {
          "type": "array",
          "description": "Assertions to evaluate against the agent response.",
          "items": { "$ref": "#/$defs/assertion" }
        }
      }
    },
    "toolDefinition": {
      "type": "object",
      "description": "A tool/function definition available to the agent.",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Tool/function name as the model sees it."
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of what the tool does."
        },
        "parameters": {
          "type": "object",
          "description": "JSON Schema defining the tool's input parameters."
        },
        "responses": {
          "type": "array",
          "description": "Simulated responses based on argument matching.",
          "items": {
            "type": "object",
            "required": ["when", "then"],
            "properties": {
              "when": {
                "type": "object",
                "description": "Condition: match tool call arguments (partial match)."
              },
              "then": {
                "description": "Simulated response to return when condition matches."
              }
            }
          }
        },
        "default_response": {
          "description": "Default simulated response when no 'when' condition matches."
        }
      }
    },
    "assertion": {
      "type": "object",
      "description": "An assertion to evaluate against the agent response.",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "tool_called",
            "tool_not_called",
            "tool_order",
            "schema",
            "judge",
            "no_pii",
            "keywords_present",
            "keywords_absent",
            "drift",
            "latency",
            "cost"
          ],
          "description": "The assertion type to evaluate."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "tool_called" } },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "type": { "const": "tool_called" },
              "value": {
                "type": "string",
                "minLength": 1,
                "description": "The name of the tool that should have been called."
              },
              "args": {
                "type": "object",
                "description": "Expected arguments (partial match). Key-value pairs that must be present in the tool call arguments."
              },
              "args_schema": {
                "type": "string",
                "description": "Path to JSON Schema file to validate the tool call arguments."
              },
              "order": {
                "type": "integer",
                "minimum": 0,
                "description": "Expected position in the sequence of tool calls (0-indexed)."
              }
            },
            "required": ["type", "value"],
            "additionalProperties": false
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "tool_not_called" } },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "type": { "const": "tool_not_called" },
              "value": {
                "type": "string",
                "minLength": 1,
                "description": "The name of the tool that should NOT have been called."
              }
            },
            "required": ["type", "value"],
            "additionalProperties": false
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "tool_order" } },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "type": { "const": "tool_order" },
              "value": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 },
                "minItems": 2,
                "description": "Ordered list of tool names that must have been called in this sequence."
              }
            },
            "required": ["type", "value"],
            "additionalProperties": false
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "schema" } },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "type": { "const": "schema" },
              "value": {
                "description": "Inline JSON Schema object or path to a JSON Schema file to validate structured output."
              },
              "schema_file": {
                "type": "string",
                "description": "Path to a JSON Schema file (relative to config file). Alternative to inline 'value'."
              }
            },
            "additionalProperties": false
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "judge" } },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "type": { "const": "judge" },
              "criteria": {
                "type": "string",
                "minLength": 1,
                "description": "Natural language description of what to evaluate (e.g., 'Response is empathetic and professional')."
              },
              "threshold": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "default": 0.7,
                "description": "Minimum score (0.0-1.0) for this criterion to pass."
              },
              "rubric": {
                "type": "string",
                "description": "Detailed scoring rubric for the judge. If omitted, a default rubric is generated from criteria."
              },
              "model": {
                "type": "string",
                "pattern": "^(openai|anthropic|gemini|mistral|cohere|ollama):.+$",
                "description": "Override judge model for this assertion."
              }
            },
            "required": ["type", "criteria"],
            "additionalProperties": false
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "no_pii" } },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "type": { "const": "no_pii" },
              "patterns": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name", "pattern"],
                  "additionalProperties": false,
                  "properties": {
                    "name": {
                      "type": "string",
                      "minLength": 1,
                      "description": "Human-readable name of the PII pattern (e.g., 'US Phone')."
                    },
                    "pattern": {
                      "type": "string",
                      "minLength": 1,
                      "description": "Regex pattern that should NOT appear in output."
                    }
                  }
                },
                "description": "Custom PII patterns to detect in addition to built-in patterns (SSN, credit card, email, phone, IBAN)."
              }
            },
            "additionalProperties": false
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "keywords_present" } },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "type": { "const": "keywords_present" },
              "keywords": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 },
                "minItems": 1,
                "description": "Phrases that MUST appear in the agent output (case-insensitive)."
              }
            },
            "required": ["type", "keywords"],
            "additionalProperties": false
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "keywords_absent" } },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "type": { "const": "keywords_absent" },
              "keywords": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 },
                "minItems": 1,
                "description": "Phrases that must NOT appear in the agent output (case-insensitive)."
              }
            },
            "required": ["type", "keywords"],
            "additionalProperties": false
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "drift" } },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "type": { "const": "drift" },
              "max_score": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "default": 0.15,
                "description": "Maximum drift score (0-1). Higher = more drift allowed. Fail if exceeded."
              },
              "method": {
                "type": "string",
                "enum": ["judge", "embedding", "field-diff"],
                "default": "judge",
                "description": "Drift detection method."
              },
              "fields": {
                "type": "array",
                "items": { "type": "string" },
                "description": "For field-diff method: JSON paths to compare (e.g., 'response.action')."
              }
            },
            "additionalProperties": false
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "latency" } },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "type": { "const": "latency" },
              "max_ms": {
                "type": "integer",
                "minimum": 1,
                "description": "Maximum response latency in milliseconds."
              }
            },
            "required": ["type", "max_ms"],
            "additionalProperties": false
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "cost" } },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "type": { "const": "cost" },
              "max_usd": {
                "type": "number",
                "exclusiveMinimum": 0,
                "description": "Maximum token cost in USD for this test case."
              }
            },
            "required": ["type", "max_usd"],
            "additionalProperties": false
          }
        }
      ]
    },
    "gates": {
      "type": "object",
      "description": "Pass/fail gates for the suite. If any gate fails, the suite fails.",
      "additionalProperties": false,
      "properties": {
        "pass_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.95,
          "description": "Minimum overall pass rate (0-1). Computed after repeats and aggregation."
        },
        "max_cost": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Maximum total cost in USD for the entire suite run."
        },
        "max_latency": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum average latency in ms. Fails gate if exceeded."
        },
        "schema_failures_max": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Maximum allowed schema validation failures."
        },
        "judge_avg_min": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Minimum average LLM-as-judge score across all criteria."
        },
        "drift_score_max": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Maximum allowed drift score against active baseline."
        },
        "pii_failures_max": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Maximum allowed PII detection failures."
        },
        "keyword_failures_max": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Maximum allowed keyword guardrail failures."
        }
      }
    }
  }
}
