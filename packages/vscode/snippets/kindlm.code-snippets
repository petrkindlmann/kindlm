{
  "kindlm-init": {
    "prefix": "kindlm-init",
    "description": "Full KindLM v2 config file skeleton",
    "body": [
      "kindlm: 1",
      "project: \"${1:my-project}\"",
      "",
      "suite:",
      "  name: \"${2:my-suite}\"",
      "  description: \"${3:Behavioral tests for my AI agent}\"",
      "",
      "providers:",
      "  ${4:openai}:",
      "    apiKeyEnv: ${5:OPENAI_API_KEY}",
      "",
      "models:",
      "  - id: ${6:gpt-4o}",
      "    provider: ${4:openai}",
      "    model: ${6:gpt-4o}",
      "    params:",
      "      temperature: 0",
      "      maxTokens: 1024",
      "",
      "prompts:",
      "  ${7:main}:",
      "    system: \"${8:You are a helpful assistant.}\"",
      "    user: \"${9:{{message}}}\"",
      "",
      "tests:",
      "  - name: \"${10:happy-path}\"",
      "    prompt: ${7:main}",
      "    vars:",
      "      ${11:message}: \"${12:Hello, how can you help me?}\"",
      "    expect:",
      "      $0",
      "",
      "gates:",
      "  passRateMin: 0.95"
    ]
  },
  "kindlm-test": {
    "prefix": "kindlm-test",
    "description": "Single KindLM v2 test case",
    "body": [
      "- name: \"${1:test-name}\"",
      "  prompt: ${2:my-prompt}",
      "  vars:",
      "    ${3:message}: \"${4:User message to the agent}\"",
      "  expect:",
      "    $0"
    ]
  },
  "kindlm-expect-tool": {
    "prefix": "kindlm-expect-tool",
    "description": "toolCalls assertion — assert a tool was called with specific arguments",
    "body": [
      "toolCalls:",
      "  - tool: ${1:tool_name}",
      "    argsMatch:",
      "      ${2:param_name}: \"${3:expected_value}\"",
      "$0"
    ]
  },
  "kindlm-expect-judge": {
    "prefix": "kindlm-expect-judge",
    "description": "judge assertion — LLM-as-judge evaluation with minScore",
    "body": [
      "judge:",
      "  - criteria: \"${1:Response is helpful, accurate, and professional}\"",
      "    minScore: ${2:0.8}",
      "$0"
    ]
  },
  "kindlm-expect-pii": {
    "prefix": "kindlm-expect-pii",
    "description": "PII guardrail — fail if SSN, credit card, email, or phone appears in output",
    "body": [
      "guardrails:",
      "  pii:",
      "    enabled: true",
      "$0"
    ]
  },
  "kindlm-expect-keywords": {
    "prefix": "kindlm-expect-keywords",
    "description": "Keyword guardrail — deny forbidden phrases from output",
    "body": [
      "guardrails:",
      "  keywords:",
      "    deny:",
      "      - \"${1:forbidden phrase}\"",
      "$0"
    ]
  },
  "kindlm-expect-output": {
    "prefix": "kindlm-expect-output",
    "description": "Output content assertion — required/forbidden substrings",
    "body": [
      "output:",
      "  contains:",
      "    - \"${1:expected phrase}\"",
      "  notContains:",
      "    - \"${2:forbidden phrase}\"",
      "$0"
    ]
  },
  "kindlm-expect-drift": {
    "prefix": "kindlm-expect-drift",
    "description": "Baseline drift assertion — detect behavioral regression",
    "body": [
      "baseline:",
      "  drift:",
      "    maxScore: ${1:0.15}",
      "    method: ${2|judge,embedding,field-diff|}",
      "$0"
    ]
  },
  "kindlm-model": {
    "prefix": "kindlm-model",
    "description": "Model configuration entry",
    "body": [
      "- id: ${1:model-id}",
      "  provider: ${2|openai,anthropic,gemini,mistral,cohere,ollama,http|}",
      "  model: ${3:model-name}",
      "  params:",
      "    temperature: ${4:0}",
      "    maxTokens: ${5:1024}",
      "$0"
    ]
  },
  "kindlm-prompt": {
    "prefix": "kindlm-prompt",
    "description": "Named prompt template with system and user messages",
    "body": [
      "${1:prompt-name}:",
      "  system: \"${2:You are a helpful assistant.}\"",
      "  user: \"${3:{{message}}}\"",
      "$0"
    ]
  }
}
