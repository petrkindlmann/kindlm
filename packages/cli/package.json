{
  "name": "@kindlm/cli",
  "version": "2.0.0",
  "type": "module",
  "license": "MIT",
  "description": "CLI for KindLM — behavioral regression testing for AI agents",
  "keywords": [
    "ai",
    "llm",
    "testing",
    "cli",
    "agents",
    "tool-calls",
    "ci-cd",
    "compliance",
    "eu-ai-act"
  ],
  "homepage": "https://kindlm.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/petrkindlmann/kindlm.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/petrkindlmann/kindlm/issues"
  },
  "bin": {
    "kindlm": "./dist/kindlm.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kindlm/core": "*",
    "commander": "^13.0.0",
    "chalk": "^5.4.0",
    "ora": "^8.1.0",
    "pdfkit": "^0.15.0"
  }
}
