      "Bash(node:*)",
      "Bash(git:*)",
      "Bash(turbo:*)",
      "Bash(wrangler:*)",
      "Bash(vitest:*)",
      "Bash(tsc:*)",
      "Bash(tsup:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Bash(mkdir:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
